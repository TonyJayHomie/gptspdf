## Uno R3 Sketch

```cpp
#include <SoftwareSerial.h>
#include <VescUart.h>

SoftwareSerial vescSerial(10, 11); // RX=10, TX=11
VescUart UART;

unsigned long lastKeepalive = 0;
float targetCurrent = 0.0;

void setup() {
Serial.begin(115200);
vescSerial.begin(19200);
UART.setSerialPort(&vescSerial);
}

void loop() {
// Read FFB current command from PC
if (Serial.available() > 0) {
targetCurrent = Serial.parseFloat();
// Clamp to safe range
targetCurrent = constrain(targetCurrent, -15.0, 15.0);
UART.setCurrent(targetCurrent);
}

// Keepalive every 50ms or VESC cuts motor
if (millis() - lastKeepalive > 50) {
UART.sendKeepalive();
lastKeepalive = millis();
}
}
```

**Library needed:** `SolidGeek/VescUart` — install via Arduino Library Manager


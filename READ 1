## PC Side — vJoy FFB Listener (C#)

```csharp
using System;
using System.IO.Ports;
using vJoyInterfaceWrap;

class FFBWheel {
static vJoy joystick = new vJoy();
static SerialPort port;
static uint id = 1; // vJoy device ID

static void Main() {
// Open serial to Uno
port = new SerialPort("COM3", 115200); // change COM port
port.Open();

// Acquire vJoy device
joystick.AcquireVJD(id);

// Register FFB callback
joystick.FfbRegisterGenCB(FfbCallback, IntPtr.Zero);

Console.WriteLine("Running. Press Enter to quit.");
Console.ReadLine();
port.Close();
}

static void FfbCallback(IntPtr data, IntPtr userData) {
vJoy.FFBPType type = joystick.Ffb_h_Type(data);

if (type == vJoy.FFBPType.PT_EFFREP) {
FFB_EFF_CONSTANT eff = new FFB_EFF_CONSTANT();
joystick.Ffb_h_Eff_Constant(data, ref eff);

// Magnitude: -10000 to +10000
// Map to current: -15A to +15A
float current = (eff.Magnitude / 10000.0f) * 15.0f;

string cmd = current.ToString("F2") + "\n";
port.Write(cmd);
}
}
}
```

